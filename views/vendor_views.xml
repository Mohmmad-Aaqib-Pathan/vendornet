<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_vn_vendor_form" model="ir.ui.view">
            <field name="name">vn.vendor.form</field>
            <field name="model">vn.vendor</field>
            <field name="arch" type="xml">
                <form string="Vendor">
                    <header>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button type="object" name="action_view_rfqs"
                            class="oe_stat_button" icon="fa-file-text-o">
                            <field name="rfq_count" widget="statinfo" string="RFQs"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="Contact">
                                <field name="email"/>
                                <field name="phone"/>
                                <field name="address"/>
                            </group>
                            <group string="Details">
                                <field name="gst_number"/>
                                <field name="category"/>
                                <field name="status"/>
                                <field name="rating"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_vn_vendor_list" model="ir.ui.view">
            <field name="name">vn.vendor.list</field>
            <field name="model">vn.vendor</field>
            <field name="arch" type="xml">
                <list string="Vendors">
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="gst_number"/>
                    <field name="category"/>
                    <field name="status"/>
                    <field name="rating"/>
                </list>
            </field>
        </record>

        <record id="action_vn_vendor" model="ir.actions.act_window">
            <field name="name">Vendors</field>
            <field name="res_model">vn.vendor</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>