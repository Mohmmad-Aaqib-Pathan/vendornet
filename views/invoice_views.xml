<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_vn_invoice_form" model="ir.ui.view">
            <field name="name">vn.invoice.form</field>
            <field name="model">vn.invoice</field>
            <field name="arch" type="xml">
                <form string="Invoice">
                    <header>
                        <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_paid" type="object" string="Mark as Paid"
                            class="btn-success" invisible="state != 'confirmed'"/>
                        <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('paid','cancelled')"/>
                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,confirmed,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="vendor_id"/>
                                <field name="po_id"/>
                                <field name="invoice_date"/>
                                <field name="due_date"/>
                            </group>
                            <group>
                                <field name="amount_total"/>
                                <field name="tax_amount"/>
                                <field name="grand_total" readonly="1"/>
                            </group>
                        </group>
                        <group string="Notes">
                            <field name="notes" nolabel="1"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_vn_invoice_list" model="ir.ui.view">
            <field name="name">vn.invoice.list</field>
            <field name="model">vn.invoice</field>
            <field name="arch" type="xml">
                <list string="Invoices"
                    decoration-success="state == 'paid'"
                    decoration-warning="state == 'confirmed'"
                    decoration-muted="state == 'cancelled'">
                    <field name="name"/>
                    <field name="vendor_id"/>
                    <field name="po_id"/>
                    <field name="invoice_date"/>
                    <field name="due_date"/>
                    <field name="amount_total"/>
                    <field name="tax_amount"/>
                    <field name="grand_total"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="action_vn_invoice" model="ir.actions.act_window">
            <field name="name">Invoices</field>
            <field name="res_model">vn.invoice</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>