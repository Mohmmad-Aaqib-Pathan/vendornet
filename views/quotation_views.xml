<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_vn_quotation_form" model="ir.ui.view">
            <field name="name">vn.quotation.form</field>
            <field name="model">vn.quotation</field>
            <field name="arch" type="xml">
                <form string="Quotation">
                    <header>
                        <button name="action_submit" type="object" string="Submit"
                            class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_select" type="object" string="Select Winner"
                            class="btn-success" invisible="state != 'submitted'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="rfq_id"/>
                                <field name="vendor_id"/>
                                <field name="validity_date"/>
                                <field name="delivery_days"/>
                            </group>
                            <group>
                                <field name="unit_price"/>
                                <field name="quantity"/>
                                <field name="total_amount" readonly="1"/>
                            </group>
                        </group>
                        <group string="Notes">
                            <field name="notes" nolabel="1"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_vn_quotation_list" model="ir.ui.view">
            <field name="name">vn.quotation.list</field>
            <field name="model">vn.quotation</field>
            <field name="arch" type="xml">
                <list string="Quotations"
                    decoration-success="state == 'selected'"
                    decoration-muted="state == 'rejected'">
                    <field name="name"/>
                    <field name="rfq_id"/>
                    <field name="vendor_id"/>
                    <field name="unit_price"/>
                    <field name="quantity"/>
                    <field name="total_amount"/>
                    <field name="delivery_days"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="action_vn_quotation" model="ir.actions.act_window">
            <field name="name">Quotations</field>
            <field name="res_model">vn.quotation</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>